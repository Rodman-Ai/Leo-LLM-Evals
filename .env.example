# Database (Neon)
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
# Optional pooled connection for serverless functions
DATABASE_URL_POOLED=

# Providers — only Anthropic is wired up in Weekend 1.
# OpenAI + Google land in Weekend 2; placeholders kept so you can wire them up early.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional — set automatically in CI.
GIT_SHA=
GIT_BRANCH=

# Optional knobs.
EVAL_CONCURRENCY=5
# Set to "true" to show a "Demo mode" banner in the dashboard. Pair with
# `pnpm db:seed` and the mock:* models to run the full app without provider keys.
PUBLIC_DEMO_MODE=false
# Strong random string. When set, the GET /api/seed?token=<this> endpoint is
# enabled — visit it once to populate the DB without local tooling. Leave
# blank in environments that shouldn't expose the seed endpoint.
SEED_TOKEN=

# >=32-char random string used to encrypt the per-visitor session cookie
# (OAuth tokens). Generate with: openssl rand -hex 32
SESSION_SECRET=

# Google OAuth — required for "Export to Google Sheets". Create a project
# at console.cloud.google.com → enable Drive API → OAuth consent screen
# (External, scopes: openid, email, drive.file) → Credentials → OAuth Client
# ID (Web application) with redirect URI:
#   https://<your-host>/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Microsoft OAuth — required for "Upload CSV to OneDrive". Create an app
# at entra.microsoft.com → App registrations → New registration ("Accounts
# in any organizational directory and personal Microsoft accounts") with
# redirect URI: https://<your-host>/api/auth/microsoft/callback
# Then API permissions → Microsoft Graph → Files.ReadWrite + User.Read
# (delegated). Generate a client secret under Certificates & secrets.
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
# Tenant id; default "common" supports both work and personal accounts.
MICROSOFT_OAUTH_TENANT=common
