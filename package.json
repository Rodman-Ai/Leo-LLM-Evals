{
	"name": "evalbench",
	"version": "0.0.1",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "next dev",
		"build": "node scripts/maybe-migrate.mjs && next build",
		"start": "next start",
		"eval": "tsx scripts/eval.ts",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "tsx scripts/seed.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "next lint",
		"format": "prettier --write ."
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^1.2.0",
		"@ai-sdk/google": "^1.2.22",
		"@ai-sdk/openai": "^1.3.24",
		"@neondatabase/serverless": "^0.10.4",
		"ai": "^4.3.0",
		"drizzle-orm": "^0.36.4",
		"next": "15.5.15",
		"p-limit": "^6.2.0",
		"react": "19.0.0",
		"react-dom": "19.0.0",
		"recharts": "^3.8.1",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"@types/react": "19.0.0",
		"@types/react-dom": "19.0.0",
		"autoprefixer": "^10.4.20",
		"drizzle-kit": "^0.30.1",
		"eslint": "^9.17.0",
		"eslint-config-next": "15.5.15",
		"eslint-config-prettier": "^9.1.0",
		"postcss": "^8.4.49",
		"prettier": "^3.4.2",
		"tailwindcss": "^3.4.17",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"vitest": "^2.1.8"
	}
}
